# ── Database ──────────────────────────────────────────────────────────────────
DATABASE_URL=postgresql+asyncpg://heliotelligence:secret@localhost:5432/heliotelligence
# Set PGPASSWORD separately or embed in DATABASE_URL; never commit real creds.

# ── Solcast ───────────────────────────────────────────────────────────────────
SOLCAST_API_KEY=your_solcast_api_key_here
# Resource IDs are per-site; comma-separated for multi-site.
# SOLCAST_RESOURCE_IDS=abcd-1234,efgh-5678

# ── App ───────────────────────────────────────────────────────────────────────
APP_ENV=development           # development | staging | production
LOG_LEVEL=INFO
SECRET_KEY=change-me-in-production

# ── Scheduler ─────────────────────────────────────────────────────────────────
SOLCAST_POLL_INTERVAL_MINUTES=60
SCADA_CSV_POLL_INTERVAL_MINUTES=5

# ── Upsert strategy ────────────────────────────────────────────────────────────
# "update" (default): ON CONFLICT DO UPDATE — requires TimescaleDB ≥ 2.11
# "ignore"          : ON CONFLICT DO NOTHING — safe for all TimescaleDB versions
UPSERT_STRATEGY=update

# ── Site config ───────────────────────────────────────────────────────────────
SITE_CONFIG_PATH=config/sites.yaml
